                            },
                            "frame_color": {
                                "bsonType": "string"
                            },
                            "lens_color": {
                                "bsonType": "object",
                                "properties": {
                                    "right": {
                                        "bsonType": "double"
                                    },
                                    "left": {
                                        "bsonType": "double"
                                    }
                                }
                            },
