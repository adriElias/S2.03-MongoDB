                                "bsonType": "string"
                            },
                            "number": {
                                "bsonType": "string"
                            },
                            "floor": {
                                "bsonType": "string"
                            },
                            "door": {
                                "bsonType": "string"
                            },
                            "city": {
                                "bsonType": "string"
                            },
